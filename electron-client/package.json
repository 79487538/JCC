{
  "name": "jcc-electron-client",
  "version": "1.0.0",
  "description": "JCC AI Assistant desktop client",
  "productName": "JCC AI Assistant",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --dir",
    "dist": "electron-builder --win nsis",
    "recover-build": "powershell -ExecutionPolicy Bypass -File build-recovery.ps1"
  },
  "build": {
    "appId": "com.jcc.jccai",
    "productName": "JCC AI Assistant",
    "asar": true,
    "compression": "maximum",
    "directories": {
      "output": "../dist"
    },
    "files": [
      "**/*",
      "!node_modules/.cache/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "JCC-AI-Setup.exe"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "devDependencies": {
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3"
  }
}
